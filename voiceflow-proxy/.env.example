PORT=3000
VOICEFLOW_API_URL=https://general-runtime.voiceflow.com
VOICEFLOW_API_KEY=VF.DM.tu_api_key_aqui
VOICEFLOW_VERSION_ID=main

# Mismo origen para index.html y /cocina.html (no incluir /cocina.html aquí)
ALLOWED_ORIGINS=https://bright-sorbet-e94b45.netlify.app,http://localhost:5500

# Carpeta donde se persisten los pedidos. En Railway monta un Volume aquí
# para que sobrevivan a los reinicios del contenedor.
DATA_DIR=./data

# Token opcional para proteger endpoints de auditoría:
# GET /api/voiceflow-usage y /api/voiceflow-usage/summary
ADMIN_TOKEN=cambia_este_token_largo

# Por defecto NO guardamos texto de conversaciones, sólo métricas.
# Pon true sólo si necesitas revisar frases concretas.
AUDIT_STORE_TEXT=false
